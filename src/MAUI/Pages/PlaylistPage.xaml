<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:root="clr-namespace:DJBuddy.MAUI"
             xmlns:models="clr-namespace:DJBuddy.MAUI.Models"
             xmlns:pages="clr-namespace:DJBuddy.MAUI.Pages"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:mct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="DJBuddy.MAUI.Pages.PlaylistPage">

    <ContentPage.Resources>
        <mct:InvertedBoolConverter x:Key="InvertedBoolConverter" />

        <DataTemplate x:Key="NodeTemplate" x:DataType="models:PlaylistNode">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Padding="16,12">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNodeTapped" />
                </Grid.GestureRecognizers>
                <Grid WidthRequest="26" VerticalOptions="Center">
                    <mi:MauiIcon Icon="{mi:Material Icon=Folder}" IconSize="20"
                                 IsVisible="{Binding IsFolder}" />
                    <mi:MauiIcon Icon="{mi:Material Icon=MusicNote}" IconSize="20"
                                 IsVisible="{Binding IsFolder, Converter={StaticResource InvertedBoolConverter}}" />
                </Grid>
                <Label Grid.Column="1" Text="{Binding Name}"
                       FontSize="16" VerticalTextAlignment="Center" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="TrackTemplate" x:DataType="pages:TrackDisplayItem">
            <SwipeView>
                <SwipeView.RightItems>
                    <SwipeItems>
                        <!-- Swipe - Right: Add Song -->
                        <SwipeItem IconImageSource="{mi:Material Icon=Add}"
                                   BackgroundColor="#2ECC71"
                                   Invoked="OnAddToSwipeInvoked" />
                    </SwipeItems>
                </SwipeView.RightItems>

                <Grid ColumnDefinitions="4,*,60,50" Padding="0,0,16,0"
                      BackgroundColor="{Binding HighlightColor}">
                    <Grid.GestureRecognizers>
                        <!-- Tap: See Compatible Songs -->
                        <TapGestureRecognizer Tapped="OnTrackTapped" />
                        
                        <!-- Right-Click: Add Song -->
                        <TapGestureRecognizer Tapped="OnTrackRightClicked" Buttons="Secondary" />
                    </Grid.GestureRecognizers>

                    <!-- Selection accent bar -->
                    <BoxView Color="{StaticResource Primary}" IsVisible="{Binding IsSelected}"
                             WidthRequest="4" HorizontalOptions="Start" />

                    <VerticalStackLayout Grid.Column="1" Spacing="2" Padding="12,8">
                        <Label Text="{Binding Track.Name}" FontSize="15"
                               LineBreakMode="TailTruncation" />
                        <Label Text="{Binding Track.Artist}" FontSize="12" TextColor="Gray"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>

                    <Label Grid.Column="2" Text="{Binding Track.BpmDisplay}" FontSize="14"
                           HorizontalTextAlignment="End" VerticalTextAlignment="Center" />
                    <Label Grid.Column="3" Text="{Binding Track.KeyDisplay}" FontSize="14"
                           HorizontalTextAlignment="End" VerticalTextAlignment="Center" />
                </Grid>
            </SwipeView>
        </DataTemplate>

        <DataTemplate x:Key="DjBuddyTrackTemplate" x:DataType="pages:TrackDisplayItem">
            <SwipeView>
                <SwipeView.RightItems>
                    <SwipeItems>
                        <!-- Swipe - Right: Remove from DJ Buddy playlist -->
                        <SwipeItem IconImageSource="{mi:Material Icon=Delete}"
                                   BackgroundColor="Red"
                                   Invoked="OnRemoveFromDjBuddyInvoked" />
                    </SwipeItems>
                </SwipeView.RightItems>

                <Grid ColumnDefinitions="4,*,60,50" Padding="0,0,16,0"
                      BackgroundColor="{Binding HighlightColor}">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTrackTapped" />
                        <TapGestureRecognizer Tapped="OnTrackRightClicked" Buttons="Secondary" />
                    </Grid.GestureRecognizers>

                    <BoxView Color="{StaticResource Primary}" IsVisible="{Binding IsSelected}"
                             WidthRequest="4" HorizontalOptions="Start" />

                    <VerticalStackLayout Grid.Column="1" Spacing="2" Padding="12,8">
                        <Label Text="{Binding Track.Name}" FontSize="15"
                               LineBreakMode="TailTruncation" />
                        <Label Text="{Binding Track.Artist}" FontSize="12" TextColor="Gray"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>

                    <Label Grid.Column="2" Text="{Binding Track.BpmDisplay}" FontSize="14"
                           HorizontalTextAlignment="End" VerticalTextAlignment="Center" />
                    <Label Grid.Column="3" Text="{Binding Track.KeyDisplay}" FontSize="14"
                           HorizontalTextAlignment="End" VerticalTextAlignment="Center" />
                </Grid>
            </SwipeView>
        </DataTemplate>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Sticky header: filter + column headers + legend -->
        <VerticalStackLayout Grid.Row="0">

            <!-- Filter bar -->
            <Grid x:Name="FilterBar" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"
                  Padding="16,4" IsVisible="False">
                <Entry x:Name="SearchEntry" Placeholder="Search title or artist..."
                       FontSize="14" ClearButtonVisibility="WhileEditing"
                       TextChanged="OnSearchTextChanged" />
                <Button x:Name="DateAddedSortButton" Grid.Column="1"
                        Text="Recently Added" FontSize="13" Padding="12,0"
                        HeightRequest="36" CornerRadius="6"
                        BackgroundColor="Transparent"
                        BorderColor="Gray" BorderWidth="1" TextColor="Gray"
                        IsVisible="False"
                        Clicked="OnDateAddedSortClicked" />
                <Button x:Name="KeyFilterButton" Grid.Column="2" Text="Key"
                        FontSize="13" Padding="12,0" HeightRequest="36"
                        CornerRadius="6" BackgroundColor="Transparent"
                        BorderColor="Gray" BorderWidth="1" TextColor="Gray"
                        Clicked="OnKeyFilterButtonClicked" />
            </Grid>

            <!-- Sortable column headers -->
            <Grid x:Name="TrackColumnHeaders" ColumnDefinitions="*,60,50"
                  Padding="16,6" IsVisible="False"
                  BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A2A}">
                <Label x:Name="TitleHeaderLabel" Text="Title" FontSize="13"
                       FontAttributes="Bold" TextColor="Gray"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTitleHeaderTapped" />
                    </Label.GestureRecognizers>
                </Label>
                <Label x:Name="BpmHeaderLabel" Grid.Column="1" Text="BPM" FontSize="13"
                       FontAttributes="Bold" TextColor="Gray"
                       HorizontalTextAlignment="End" VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBpmHeaderTapped" />
                    </Label.GestureRecognizers>
                </Label>
                <Label x:Name="KeyHeaderLabel" Grid.Column="2" Text="Key" FontSize="13"
                       FontAttributes="Bold" TextColor="Gray"
                       HorizontalTextAlignment="End" VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnKeyHeaderTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <!-- Key compatibility legend (always visible when tracks are loaded) -->
            <Grid x:Name="KeyLegend" IsVisible="False"
                  ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                  RowSpacing="4" ColumnSpacing="8" Padding="16,6"
                  BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#252525}">
                <HorizontalStackLayout x:Name="LegendSameItem" Spacing="6">
                    <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="2"
                             Color="#48D868" VerticalOptions="Center" />
                    <Label x:Name="LegendSameLabel" FontSize="11" TextColor="Gray"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout x:Name="LegendAdjacentItem" Grid.Column="1" Spacing="6">
                    <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="2"
                             Color="#5B9FD4" VerticalOptions="Center" />
                    <Label x:Name="LegendAdjacentLabel" FontSize="11" TextColor="Gray"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout x:Name="LegendBoostItem" Grid.Row="1" Spacing="6">
                    <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="2"
                             Color="#F0883C" VerticalOptions="Center" />
                    <Label x:Name="LegendBoostLabel" FontSize="11" TextColor="Gray"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout x:Name="LegendDropItem" Grid.Row="1" Grid.Column="1" Spacing="6">
                    <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="2"
                             Color="#A77BCA" VerticalOptions="Center" />
                    <Label x:Name="LegendDropLabel" FontSize="11" TextColor="Gray"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
            </Grid>

        </VerticalStackLayout>

        <!-- Scrollable content -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*">

            <!-- Playlists section (small, non-scrolling) -->
            <VerticalStackLayout Grid.Row="0">
                <Label x:Name="PlaylistsHeader" Text="PLAYLISTS"
                       FontSize="13" FontAttributes="Bold" TextColor="Gray"
                       Padding="16,16,16,4" IsVisible="False" />
                <VerticalStackLayout x:Name="NodeList"
                                     BindableLayout.ItemTemplate="{StaticResource NodeTemplate}" />
                <Label x:Name="TracksHeader" Text="TRACKS"
                       FontSize="13" FontAttributes="Bold" TextColor="Gray"
                       Padding="16,16,16,4" IsVisible="False" />
            </VerticalStackLayout>

            <!-- Track list with virtualization -->
            <CollectionView x:Name="TrackList" Grid.Row="1"
                            ItemSizingStrategy="MeasureFirstItem" />

            <!-- Sorting progress overlay -->
            <ActivityIndicator x:Name="SortingIndicator" Grid.Row="1"
                               IsVisible="False" IsRunning="False"
                               VerticalOptions="Center" HorizontalOptions="Center" />

        </Grid>

    </Grid>

</ContentPage>
