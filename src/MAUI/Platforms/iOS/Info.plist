<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>DJ Buddy</string>

	<key>CFBundleName</key>
	<string>DJ Buddy</string>

	<!-- No custom encryption used - only standard OS/HTTPS, exempt from export compliance -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- Share files to/from app via Finder/iTunes -->
	<key>UIFileSharingEnabled</key>
	<true/>

	<!-- Open files in-place (i.e. Files app) instead of copying them -->
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>

	<!-- Register as a handler for .xml files so users can "Open with DJ Buddy" -->
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<!-- Human-readable name for this document type, shown in the "Open with" menu -->
			<key>CFBundleTypeName</key>
			<string>rekordbox Library</string>
			<!-- UTIs this app can open; public.xml covers any .xml file -->
			<key>LSItemContentTypes</key>
			<array>
				<string>public.xml</string>
			</array>
			<!-- App's role for this type: Viewer = can open but not edit/create -->
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<!-- Priority when multiple apps can handle this type:
			     Owner = primary handler, Alternate = secondary, None = last resort.
			     Alternate is correct since .xml is a generic type owned by other apps. -->
			<key>LSHandlerRank</key>
			<string>Alternate</string>
		</dict>
	</array>

	<key>LSRequiresIPhoneOS</key>
	<true/>

	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer>
		<integer>2</integer>
	</array>

	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>

	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<key>XSAppIconAssets</key>
	<string>Assets.xcassets/appicon.appiconset</string>

	<!-- Opt into iOS 26 compatibility mode to avoid crash in UIWindowScene's
	     new @Observable corner provider feature, which is incompatible with
	     apps not built with the Xcode 26 SDK. -->
	<key>UIDesignRequiresCompatibility</key>
	<true/>

	<!-- Privacy usage descriptions required by Apple because included frameworks
	     (MAUI, MCT, MauiIcons) reference these APIs. DJ Buddy does not use them
	     directly, but the keys must be present to pass App Store validation when
	     linking is disabled (MtouchLink=None). -->
	<key>NSCalendarsUsageDescription</key>
	<string>DJ Buddy does not access your calendars.</string>
	<key>NSContactsUsageDescription</key>
	<string>DJ Buddy does not access your contacts.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>DJ Buddy does not access your microphone.</string>
	<key>NSAppleMusicUsageDescription</key>
	<string>DJ Buddy does not access your Apple Music library.</string>
	<key>NSSiriUsageDescription</key>
	<string>DJ Buddy does not use Siri.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>DJ Buddy does not access your location.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>DJ Buddy does not access your location.</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>DJ Buddy does not use Bluetooth.</string>
</dict>
</plist>
