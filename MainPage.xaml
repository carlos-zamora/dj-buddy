<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:dj_buddy"
             xmlns:models="clr-namespace:dj_buddy.Models"
             x:Class="dj_buddy.MainPage"
             Title="DJ Buddy">

    <ContentPage.Resources>
        <local:FolderIconConverter x:Key="FolderIconConverter" />
    </ContentPage.Resources>

    <Grid>
        <!-- State 1: No library loaded -->
        <Grid x:Name="WelcomeView" IsVisible="True"
              VerticalOptions="Center" HorizontalOptions="Center"
              RowDefinitions="Auto,Auto,Auto" RowSpacing="20"
              Padding="30">

            <Label Grid.Row="0"
                   Text="Welcome to DJ Buddy"
                   FontSize="28" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />

            <Label Grid.Row="1"
                   Text="Load your rekordbox.xml to get started"
                   FontSize="16" TextColor="Gray"
                   HorizontalTextAlignment="Center" />

            <Button Grid.Row="2"
                    Text="Load rekordbox.xml"
                    Clicked="OnPickFileClicked"
                    HorizontalOptions="Center" />
        </Grid>

        <!-- State 2: Library loaded -->
        <Grid x:Name="LibraryView" IsVisible="False"
              RowDefinitions="Auto,*">

            <!-- Header: filename, path, export, and change button -->
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Padding="16,12">
                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                    <Label x:Name="FileNameLabel"
                           FontSize="16" FontAttributes="Bold"
                           LineBreakMode="TailTruncation"/>
                    <Label x:Name="FilePathLabel"
                           FontSize="12" TextColor="Gray"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Export" FontSize="13"
                        Padding="12,6"
                        Clicked="OnExportClicked"
                        VerticalOptions="Center" />

                <Button Grid.Column="2"
                        Text="Change File" FontSize="13"
                        Padding="12,6"
                        Clicked="OnPickFileClicked"
                        VerticalOptions="Center" />
            </Grid>

            <!-- Playlist sections -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout>

                    <!-- DJ BUDDY section header -->
                    <Grid x:Name="DjBuddySectionHeader" Padding="16,12"
                          BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A2A}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDjBuddySectionTapped" />
                        </Grid.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label x:Name="DjBuddyCollapseIcon" Text="&#x25BC;"
                                   FontSize="12" VerticalTextAlignment="Center" TextColor="Gray" />
                            <Label Text="DJ BUDDY" FontSize="13" FontAttributes="Bold"
                                   TextColor="Gray" VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- DJ BUDDY playlists -->
                    <VerticalStackLayout x:Name="DjBuddyPlaylistList">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems>
                                            <SwipeItem Text="Rename" BackgroundColor="DodgerBlue"
                                                       Invoked="OnDjBuddyPlaylistLongPressed" />
                                            <SwipeItem Text="Delete" BackgroundColor="Red"
                                                       Invoked="OnDjBuddyPlaylistDelete" />
                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Padding="16,12">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnPlaylistItemTapped" />
                                            <TapGestureRecognizer Buttons="Secondary"
                                                                  Tapped="OnDjBuddyPlaylistLongPressed" />
                                        </Grid.GestureRecognizers>
                                        <Label Grid.Column="0" FontSize="16" VerticalTextAlignment="Center"
                                               Text="{Binding IsFolder, Converter={StaticResource FolderIconConverter}}" />
                                        <Label Grid.Column="1" FontSize="16" VerticalTextAlignment="Center"
                                               Text="{Binding Name}" />
                                    </Grid>
                                </SwipeView>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <!-- REKORDBOX section header -->
                    <Grid Padding="16,12"
                          BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A2A}">
                        <Label Text="REKORDBOX" FontSize="13" FontAttributes="Bold"
                               TextColor="Gray" VerticalTextAlignment="Center" />
                    </Grid>

                    <!-- Rekordbox playlists -->
                    <VerticalStackLayout x:Name="RekordboxPlaylistList">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Padding="16,12">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPlaylistItemTapped" />
                                    </Grid.GestureRecognizers>
                                    <Label Grid.Column="0" FontSize="16" VerticalTextAlignment="Center"
                                           Text="{Binding IsFolder, Converter={StaticResource FolderIconConverter}}" />
                                    <Label Grid.Column="1" FontSize="16" VerticalTextAlignment="Center"
                                           Text="{Binding Name}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>

</ContentPage>
