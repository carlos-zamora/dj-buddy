<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:dj_buddy"
             xmlns:models="clr-namespace:dj_buddy.Models"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:mct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="dj_buddy.MainPage"
             Title="DJ Buddy">

    <ContentPage.Resources>
        <mct:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        <local:IsNotFavoritesConverter x:Key="IsNotFavoritesConverter" />
    </ContentPage.Resources>

    <Grid x:Name="PageRoot">
        <mct:StateContainer.StateViews>

        <!-- State 1: No library loaded -->
        <Grid mct:StateView.StateKey="Welcome"
              VerticalOptions="Center" HorizontalOptions="Center"
              RowDefinitions="Auto,Auto,Auto" RowSpacing="20"
              Padding="30">

            <Label Grid.Row="0"
                   Text="Welcome to DJ Buddy"
                   FontSize="28" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />

            <Label Grid.Row="1"
                   Text="Load your rekordbox.xml to get started"
                   FontSize="16" TextColor="Gray"
                   HorizontalTextAlignment="Center" />

            <Button Grid.Row="2"
                    Text="Load rekordbox.xml"
                    ImageSource="{mi:Material Icon=FolderOpen}"
                    ContentLayout="Left, 8"
                    Clicked="OnPickFileClicked"
                    HorizontalOptions="Center" />
        </Grid>

        <!-- State 2: Library loaded -->
        <Grid mct:StateView.StateKey="Library"
              RowDefinitions="Auto,*">

            <!-- Header: filename, path, export, and change button -->
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Padding="16,12">
                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                    <Label x:Name="FileNameLabel"
                           FontSize="16" FontAttributes="Bold"
                           LineBreakMode="TailTruncation"/>
                    <Label x:Name="FilePathLabel"
                           FontSize="12" TextColor="Gray"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Export" FontSize="13"
                        Padding="12,6"
                        ImageSource="{mi:Material Icon=FileUpload}"
                        ContentLayout="Left, 6"
                        Clicked="OnExportClicked"
                        VerticalOptions="Center" />

                <Button Grid.Column="2"
                        Text="Browse..." FontSize="13"
                        Padding="12,6"
                        ImageSource="{mi:Material Icon=FolderOpen}"
                        ContentLayout="Left, 6"
                        Clicked="OnPickFileClicked"
                        VerticalOptions="Center" />
            </Grid>

            <!-- Playlist sections -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout>

                    <!-- DJ BUDDY section -->
                    <mct:Expander x:Name="DjBuddyExpander" IsExpanded="True">
                        <mct:Expander.Header>
                            <Grid Padding="16,12"
                                  BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A2A}">
                                <HorizontalStackLayout Spacing="8">
                                    <mi:MauiIcon Icon="{mi:Material Icon=ExpandMore}" IconSize="14"
                                                 IconColor="Gray" VerticalOptions="Center"
                                                 IsVisible="{Binding IsExpanded, Source={x:Reference DjBuddyExpander}}" />
                                    <mi:MauiIcon Icon="{mi:Material Icon=ChevronRight}" IconSize="14"
                                                 IconColor="Gray" VerticalOptions="Center"
                                                 IsVisible="{Binding IsExpanded, Source={x:Reference DjBuddyExpander},
                                                             Converter={StaticResource InvertedBoolConverter}}" />
                                    <Label Text="DJ BUDDY" FontSize="13" FontAttributes="Bold"
                                           TextColor="Gray" VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                            </Grid>
                        </mct:Expander.Header>

                        <!-- DJ BUDDY playlists -->
                        <VerticalStackLayout x:Name="DjBuddyPlaylistList">
                            <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems>
                                            <SwipeItem IconImageSource="{mi:Material Icon=Edit}"
                                                       BackgroundColor="DodgerBlue"
                                                       IsVisible="{Binding Name, Converter={StaticResource IsNotFavoritesConverter}}"
                                                       Invoked="OnDjBuddySwipeRename" />
                                            <SwipeItem IconImageSource="{mi:Material Icon=Delete}"
                                                       BackgroundColor="Red"
                                                       IsVisible="{Binding Name, Converter={StaticResource IsNotFavoritesConverter}}"
                                                       Invoked="OnDjBuddyPlaylistDelete" />
                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Padding="16,12">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnPlaylistItemTapped" />
                                            
                                            <!--Desktop Right-Click: context menu-->
                                            <TapGestureRecognizer Buttons="Secondary"
                                                                  Tapped="OnDjBuddyRightClicked" />
                                        </Grid.GestureRecognizers>
                                        <Grid Grid.Column="0" WidthRequest="26" VerticalOptions="Center">
                                            <mi:MauiIcon Icon="{mi:Material Icon=Folder}" IconSize="20"
                                                         IsVisible="{Binding IsFolder}" />
                                            <mi:MauiIcon Icon="{mi:Material Icon=MusicNote}" IconSize="20"
                                                         IsVisible="{Binding IsFolder, Converter={StaticResource InvertedBoolConverter}}" />
                                        </Grid>
                                        <Label Grid.Column="1" FontSize="16" VerticalTextAlignment="Center"
                                               Text="{Binding Name}" />
                                    </Grid>
                                </SwipeView>
                            </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </mct:Expander>

                    <!-- REKORDBOX section header -->
                    <Grid Padding="16,12"
                          BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A2A}">
                        <Label Text="REKORDBOX" FontSize="13" FontAttributes="Bold"
                               TextColor="Gray" VerticalTextAlignment="Center" />
                    </Grid>

                    <!-- Collection entry: all tracks in the library -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Padding="16,12">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCollectionTapped" />
                        </Grid.GestureRecognizers>
                        <Grid Grid.Column="0" WidthRequest="26" VerticalOptions="Center">
                            <mi:MauiIcon Icon="{mi:Material Icon=LibraryMusic}" IconSize="20" />
                        </Grid>
                        <Label Grid.Column="1" FontSize="16" VerticalTextAlignment="Center"
                               Text="Collection" />
                    </Grid>

                    <!-- Rekordbox playlists -->
                    <VerticalStackLayout x:Name="RekordboxPlaylistList">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Padding="16,12">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPlaylistItemTapped" />
                                    </Grid.GestureRecognizers>
                                    <Grid Grid.Column="0" WidthRequest="26" VerticalOptions="Center">
                                        <mi:MauiIcon Icon="{mi:Material Icon=Folder}" IconSize="20"
                                                     IsVisible="{Binding IsFolder}" />
                                        <mi:MauiIcon Icon="{mi:Material Icon=MusicNote}" IconSize="20"
                                                     IsVisible="{Binding IsFolder, Converter={StaticResource InvertedBoolConverter}}" />
                                    </Grid>
                                    <Label Grid.Column="1" FontSize="16" VerticalTextAlignment="Center"
                                           Text="{Binding Name}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        </mct:StateContainer.StateViews>
    </Grid>

</ContentPage>
