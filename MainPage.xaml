<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:dj_buddy"
             x:Class="dj_buddy.MainPage"
             Title="DJ Buddy">

    <ContentPage.Resources>
        <local:FolderIconConverter x:Key="FolderIconConverter" />
    </ContentPage.Resources>

    <Grid>
        <!-- State 1: No library loaded -->
        <Grid x:Name="WelcomeView" IsVisible="True"
              VerticalOptions="Center" HorizontalOptions="Center"
              RowDefinitions="Auto,Auto,Auto" RowSpacing="20"
              Padding="30">

            <Label Grid.Row="0"
                   Text="Welcome to DJ Buddy"
                   FontSize="28" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />

            <Label Grid.Row="1"
                   Text="Load your rekordbox.xml to get started"
                   FontSize="16" TextColor="Gray"
                   HorizontalTextAlignment="Center" />

            <Button Grid.Row="2"
                    Text="Load rekordbox.xml"
                    Clicked="OnPickFileClicked"
                    HorizontalOptions="Center" />
        </Grid>

        <!-- State 2: Library loaded -->
        <Grid x:Name="LibraryView" IsVisible="False"
              RowDefinitions="Auto,*">

            <!-- Header: filename, path, and change button -->
            <Grid ColumnDefinitions="*,Auto" Padding="16,12">
                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                    <Label x:Name="FileNameLabel"
                           FontSize="16" FontAttributes="Bold" />
                    <Label x:Name="FilePathLabel"
                           FontSize="12" TextColor="Gray"
                           LineBreakMode="MiddleTruncation" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Change File" FontSize="13"
                        Padding="12,6"
                        Clicked="OnPickFileClicked"
                        VerticalOptions="Center" />
            </Grid>

            <!-- Playlist list -->
            <CollectionView x:Name="PlaylistList" Grid.Row="1"
                            SelectionMode="Single"
                            SelectionChanged="OnPlaylistSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Padding="16,12">
                            <Label Text="{Binding IsFolder, Converter={StaticResource FolderIconConverter}}"
                                   FontSize="16" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding Name}"
                                   FontSize="16" VerticalTextAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>

</ContentPage>
