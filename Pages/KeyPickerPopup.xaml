<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="dj_buddy.Pages.KeyPickerPopup">

    <Border StrokeShape="RoundRectangle 12"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
            Padding="16" WidthRequest="300">
        <VerticalStackLayout Spacing="12">
            <Label Text="Filter by Key" FontSize="18" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
            <Grid x:Name="KeyGrid" ColumnDefinitions="*,*"
                  RowSpacing="6" ColumnSpacing="6" />
            <Button Text="Clear" Clicked="OnKeyPickerClear"
                    BackgroundColor="Transparent" TextColor="Gray" />
        </VerticalStackLayout>
    </Border>

</ContentView>
